<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
      Steam content downloads can be routed to dynamic third-party CDN hosts that still serve over
      plain HTTP. Restricting cleartext to a fixed domain list causes valid Workshop downloads to
      fail when Steam selects a different CDN provider.
    -->
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
